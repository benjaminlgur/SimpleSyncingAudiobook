# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=dev:your-deployment-name
CONVEX_URL=https://your-deployment-name.convex.cloud
CONVEX_SITE_URL=https://your-deployment-name.convex.site

# Hosted deployment URL (the shared Convex project for Google sign-in users)
# Set this to enable the "Sign in with Google" option in the app.
# Leave blank to only offer the "bring your own URL" option.
VITE_HOSTED_CONVEX_URL=
EXPO_PUBLIC_HOSTED_CONVEX_URL=

# Google OAuth credentials (set these in the Convex dashboard, not here)
# AUTH_GOOGLE_ID=your-google-client-id
# AUTH_GOOGLE_SECRET=your-google-client-secret

# Hosted Convex Auth variables (set these in the Convex dashboard, not here)
# REQUIRE_AUTH=true
# JWT_PRIVATE_KEY=generated-private-key
# JWKS=matching-jwks-json
# SITE_URL=http://tauri.localhost

# Do NOT set REQUIRE_AUTH=true for personal self-hosted deployments. It is only
# for the shared hosted deployment that powers Google sign-in.
