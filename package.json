      "esbuild"
    ]
  },
  "version": "0.4.3",
  "dependencies": {
    "@auth/core": "0.37.0",
    "@convex-dev/auth": "^0.0.91",
    "@convex-dev/rate-limiter": "^0.3.2",
    "expo": "~52.0.49",
