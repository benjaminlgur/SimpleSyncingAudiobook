{
  "expo": {
    "name": "Audiobook Player",
    "slug": "audiobook-player",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "audiobook-player",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f97316"
      },
      "package": "com.audiobook.player"
    },
    "plugins": [
      "expo-router",
      "expo-document-picker"
    ],
    "ios": {
      "bundleIdentifier": "com.audiobook.player"
    }
  }
}
