{
  "expo": {
    "name": "Simple Syncing Audiobook",
    "slug": "simple-syncing-audiobook",
    "version": "0.4.3",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "scheme": "simple-syncing-audiobook",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.simplesyncing.audiobook"
    },
    "plugins": [
      "expo-router",
      "expo-document-picker",
      "expo-system-ui"
    ],
    "ios": {
      "bundleIdentifier": "com.simplesyncing.audiobook"
    }
  }
}
